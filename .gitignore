# build output
/dist/
/actl
/spike-barrier
*.test

# local dev workspace (editor convenience; the build resolves act via the
# replace directive in go.mod, so CI does not need this)
/go.work
/go.work.sum

# secrets / vars / env loaded by actl (act's dotenv triple) — never commit these
.env
.env.*
!.env.example
.secrets
.secrets.*
.vars
.vars.*

# demo recordings — rendered media is hosted on GitHub (user-attachments CDN),
# not committed; keep the binaries out of the repo. The .tape (recording script)
# is text and may be committed for reproducibility.
demo/*.gif
demo/*.mp4
demo/*.webm

# editor / OS
.DS_Store
.idea/
.vscode/
.claude/
CLAUDE.md
