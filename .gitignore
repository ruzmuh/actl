# build output
/dist/
/actl
/spike-barrier
*.test

# local dev workspace (editor convenience; the build resolves act via the
# replace directive in go.mod, so CI does not need this)
/go.work
/go.work.sum

# secrets / vars / env loaded by actl (act's dotenv triple) — never commit these
.env
.env.*
!.env.example
.secrets
.secrets.*
.vars
.vars.*

# editor / OS
.DS_Store
.idea/
.vscode/
